rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Runtime content is public-read so the app can load without login.
    match /fire/{fileName} {
      allow read: if fileName.matches('fire_.*\\.json');
      allow write: if false;
    }

    match /fire/raw/images/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Deny every non-runtime object by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
